{
  "name": "@capella/database",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "development": "./src/index.ts", "default": "./dist/index.js" },
    "./schema": { "types": "./src/schema/index.ts", "development": "./src/schema/index.ts", "default": "./dist/schema/index.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=../../.env node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "node --env-file=../../.env node_modules/tsx/dist/cli.mjs src/seed/index.ts",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "dependencies": { "mysql2": "^3.14.2", "drizzle-orm": "^0.45.2" },
  "devDependencies": {
    "@capella/eslint-config": "workspace:*",
    "@capella/typescript-config": "workspace:*",
    "@types/node": "^24.0.14",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.31.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
