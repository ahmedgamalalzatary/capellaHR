{
  "name": "capella-hr",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "db:generate": "pnpm --filter @capella/api db:generate",
    "db:migrate": "pnpm --filter @capella/api db:migrate",
    "db:push": "pnpm --filter @capella/api db:push",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "dev": "turbo run dev",
    "knip": "pnpm dlx knip",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "9.39.4",
    "knip": "^5.64.1",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
