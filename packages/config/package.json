{
  "name": "@capella/config",
  "private": true,
  "type": "module",
  "exports": {
    "./server": { "types": "./src/server.ts", "development": "./src/server.ts", "default": "./dist/server.js" },
    "./client": { "types": "./src/client.ts", "development": "./src/client.ts", "default": "./dist/client.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "dependencies": { "zod": "catalog:" },
  "devDependencies": {
    "@capella/eslint-config": "workspace:*",
    "@capella/typescript-config": "workspace:*",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
