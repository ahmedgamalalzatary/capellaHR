{
  "name": "@capella/shared",
  "private": true,
  "type": "module",
  "exports": {
    ".": { "types": "./src/index.ts", "development": "./src/index.ts", "default": "./dist/index.js" },
    "./types": { "types": "./src/types/index.ts", "development": "./src/types/index.ts", "default": "./dist/types/index.js" },
    "./constants": { "types": "./src/constants/index.ts", "development": "./src/constants/index.ts", "default": "./dist/constants/index.js" },
    "./enums": { "types": "./src/enums/index.ts", "development": "./src/enums/index.ts", "default": "./dist/enums/index.js" },
    "./utils": { "types": "./src/utils/index.ts", "development": "./src/utils/index.ts", "default": "./dist/utils/index.js" },
    "./schemas": { "types": "./src/schemas/index.ts", "development": "./src/schemas/index.ts", "default": "./dist/schemas/index.js" }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "devDependencies": {
    "@capella/eslint-config": "workspace:*",
    "@capella/typescript-config": "workspace:*",
    "@types/node": "^24.13.3",
    "eslint": "^9.31.0",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "zod": "catalog:"
  }
}
