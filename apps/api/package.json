{
  "name": "@capella/api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx --conditions=development watch --env-file=../../.env src/server.ts",
    "start": "node --env-file=../../.env dist/server.js",
    "lint": "eslint .",
    "test": "vitest run && pnpm test:runtime:development",
    "test:runtime": "node --env-file=../../.env.test production-runtime-smoke.mjs",
    "test:runtime:development": "tsx --conditions=development --env-file=../../.env.test production-runtime-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@capella/config": "workspace:*",
    "@capella/contracts": "workspace:*",
    "@capella/database": "workspace:*",
    "@capella/shared": "workspace:*",
    "@simplewebauthn/server": "^13.3.2",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.7",
    "express": "^5.1.0",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "multer": "^2.2.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@capella/eslint-config": "workspace:*",
    "@capella/testing": "workspace:*",
    "@capella/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.14",
    "@types/supertest": "^7.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.31.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
