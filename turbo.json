{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "clean": {
      "cache": false
    },
    "@capella/shared#build": { "dependsOn": ["^build"], "outputs": [] },
    "@capella/contracts#build": { "dependsOn": ["^build"], "outputs": [] },
    "@capella/testing#build": { "dependsOn": ["^build"], "outputs": [] },
    "@capella/ui#build": { "dependsOn": ["^build"], "outputs": [] },
    "@capella/config#build": { "dependsOn": ["^build"], "outputs": [] },
    "@capella/database#build": { "dependsOn": ["^build"], "outputs": [] }
  }
}
