NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
DATABASE_URL=mysql://root:password@localhost:3306/capella_hr
LOG_LEVEL=debug
# Optional; set only to the verified number of trusted reverse-proxy hops (for example, 1 for one local Nginx proxy).
# TRUST_PROXY_HOPS=1
WEB_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=Capella HR
# Optional; defaults to the hostname from WEB_ORIGIN.
# WEBAUTHN_RP_ID=localhost
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_admin_password
