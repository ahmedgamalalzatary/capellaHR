NODE_ENV=development
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
DATABASE_URL=mysql://capella_hr:replace_with_database_password@db:3306/capella_hr
# Used by the production MySQL container. Keep these values consistent with DATABASE_URL.
MYSQL_DATABASE=capella_hr
MYSQL_USER=capella_hr
MYSQL_PASSWORD=replace_with_database_password
MYSQL_ROOT_PASSWORD=replace_with_root_database_password
LOG_LEVEL=debug
APP_TIME_ZONE=Africa/Cairo
APP_LOCALE=ar-EG-u-nu-latn
MAX_EMPLOYEE_IMAGE_BYTES=16777216
# Optional; set only to the verified number of trusted reverse-proxy hops (for example, 1 for one local Nginx proxy).
# TRUST_PROXY_HOPS=1
WEB_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=Capella HR
# Optional; defaults to the hostname from WEB_ORIGIN.
# WEBAUTHN_RP_ID=localhost
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_admin_password
